{
  "version": 7,
  "media_root": "~/Media/Liminal",
  "volume": 100,
  "muted": false,
  "video_playback_backend": "inapp",
  "download_quality": "1080",

  "youtube_auth_mode": "oauth",
  "youtube_browser": "firefox",
  "youtube_browser_profile": "",
  "youtube_cookies_file": "",

  "liminal.sidebar.width": 220,
  "liminal.sidebar.visible": true,
  "liminal.search.width": 340,
  "liminal.search.placeholder": "Tìm trong thư viện…",
  "liminal.playerBar.height": 108,
  "liminal.playerBar.alwaysVisible": false,
  "liminal.window.customTitleBar": true,
  "liminal.layout.gridColumns": 5,
  "liminal.layout.contentPadding": 24,
  "liminal.layout.cardRadius": 12,
  "liminal.layout.cardGap": 20,

  "liminal.colorCustomizations": {
    "accent": "#a855f7",
    "bgElevated": "#000000",
    "bgCard": "#0a0a0a",
    "textPrimary": "#ffffff"
  }
}
